{
  "name": "@espresso-lab/mantine-cognito",
  "private": false,
  "description": "Mantine UI components with AWS Cognito",
  "version": "2.0.1",
  "type": "module",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": {
    "name": "Espresso Lab",
    "email": "mail@espresso-lab.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espresso-lab/mantine-cognito"
